.comment-author{ font-size:13px; font-weight:700; color:var(--text); }
.comment-time{ font-size:11px; color:var(--text-muted); }
.comment-text{ font-size:13.5px; color:var(--text); line-height:1.5; white-space:pre-wrap; }
