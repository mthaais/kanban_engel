}
.label-edit-actions button:hover{ transform:translateY(-2px); box-shadow:var(--shadow-sm); }
.label-edit-actions .danger{ color:var(--danger); }

.new-label-block{ margin-top:20px; padding-top:20px; border-top:1px solid var(--border); }
.new-label-block input{ margin-bottom:14px; }

/* ---------- Label chips (compact, Trello-style) ---------- */
.label-chips-row{ display:flex; flex-wrap:wrap; gap:8px; align-items:center; }
.label-pill{ font-size:12px; font-weight:700; padding:6px 12px; border-radius:6px; }
.add-label-btn{
