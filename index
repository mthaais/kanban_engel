.label-list{ display:flex; flex-direction:column; gap:10px; }

.label-row-item{ display:flex; align-items:center; gap:12px; padding:14px; border-radius:14px; transition:var(--transition); cursor: pointer; }
.label-row-item:hover{ background:var(--surface-3); }
.label-row-item.unselected{ opacity:.45; }
