  let r = parseInt(c.substr(0, 2), 16), g = parseInt(c.substr(2, 2), 16), b = parseInt(c.substr(4, 2), 16);
  r = Math.round(r * (1 - factor)); g = Math.round(g * (1 - factor)); b = Math.round(b * (1 - factor));
  return `#${r.toString(16).padStart(2, '0')}${g.toString(16).padStart(2, '0')}${b.toString(16).padStart(2, '0')}`;
}

function boardColor(board) { return (BOARD_STYLE[board.slug] || {}).color || board.color || '#64748B'; }
function boardBgColor(board) { return (BOARD_STYLE[board.slug] || {}).bg || boardColor(board) + '22'; }
function boardDarkColor(board) { return (BOARD_STYLE[board.slug] || {}).dark || darkenColor(boardColor(board), 0.35); }

function accentStyle(board) {
  return `--accent:${boardColor(board)};--accent-bg:${boardBgColor(board)};--accent-dark:${boardDarkColor(board)};`;
}

const LABEL_PALETTE = ['#4C6EF5','#8B5CF6','#EC4899','#EF4444','#F97316','#EAB308','#22C55E','#14B8A6','#64748B'];
const COLOR_NAMES = {
  '#4C6EF5': 'azul', '#8B5CF6': 'roxo', '#EC4899': 'rosa', '#EF4444': 'vermelho',
  '#F97316': 'laranja', '#EAB308': 'amarelo', '#22C55E': 'verde', '#14B8A6': 'turquesa',
  '#64748B': 'cinza',
};
function colorName(hex) { return COLOR_NAMES[hex] || 'etiqueta'; }

function contrastText(hex) {
  const c = hex.replace('#', '');
  const r = parseInt(c.substr(0,2),16), g = parseInt(c.substr(2,2),16), b = parseInt(c.substr(4,2),16);
  const yiq = (r*299 + g*587 + b*114) / 1000;
  return yiq >= 150 ? '#241f18' : '#ffffff';
}

