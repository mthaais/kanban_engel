.loading-msg, .empty-state{ display:flex; justify-content:center; align-items:center; flex-direction:column; gap:14px; padding:80px 20px; color:var(--text-muted); font-size:15px; }

/* ---------- Settings page ---------- */
.settings-wrap{ padding:32px 40px; max-width:640px; }
.settings-title{ font-size:24px; font-weight:700; color:var(--text); margin-bottom:28px; }
.settings-section{ margin-bottom:32px; padding-bottom:32px; border-bottom:1px solid var(--border); }
.settings-section:last-child{ border-bottom:none; }
.settings-toggle-row{ display:flex; align-items:center; gap:10px; font-size:14px; font-weight:500; color:var(--text); cursor:pointer; }
.settings-toggle-row input[type=checkbox]{ width:36px; height:20px; accent-color:var(--primary); cursor:pointer; }
.settings-board-row{ display:flex; align-items:center; gap:10px; margin-bottom:12px; }
.settings-board-color{ width:16px; height:16px; border-radius:50%; flex-shrink:0; }
.settings-board-name{
    flex:1; height:40px; border:1px solid var(--border); border-radius:10px; padding:0 12px;
    font-size:13.5px; font-family:inherit; background:var(--surface-2); transition:var(--transition);
}
.settings-board-name:focus{ outline:none; border-color:var(--primary); background:var(--surface); }
.settings-save-status{ font-size:12px; color:var(--success); font-weight:600; min-width:44px; }

/* ---------- Auth gate ---------- */
.auth-gate{
    display:flex; align-items:center; justify-content:center; min-height:100vh;
    padding:20px;
    background:
      radial-gradient(circle at 18% 18%, rgba(76,110,245,.14), transparent 48%),
      radial-gradient(circle at 82% 78%, rgba(201,124,109,.16), transparent 48%),
      var(--bg);
}
.auth-card{
    width:100%; max-width:380px; background:var(--surface); border-radius:20px;
    padding:36px 32px; box-shadow:var(--shadow-lg); text-align:center;
}
.auth-card h1{ font-size:20px; font-weight:700; color:var(--text); margin-bottom:8px; }
.auth-card p{ font-size:13.5px; color:var(--text-light); margin-bottom:20px; }
.auth-card input[type=email]{
    width:100%; height:44px; border:1px solid var(--border); border-radius:12px;
    padding:0 14px; font-size:14px; font-family:inherit; background:var(--surface-2);
    color:var(--text); margin-bottom:12px; transition:var(--transition);
}
.auth-card input[type=email]:focus{ outline:none; border-color:var(--primary); background:var(--surface); box-shadow:0 0 0 4px rgba(91,124,250,.12); }
.auth-status{ font-size:12.5px; margin-top:12px; color:var(--text-muted); min-height:18px; }
.auth-status.success{ color:var(--success); }
.auth-status.error{ color:var(--danger); }

/* ---------- Undo toast ---------- */
.undo-toast{
    position:fixed; bottom:28px; left:50%; transform:translateX(-50%);
    background:var(--text); color:var(--text-inverse); padding:13px 16px 13px 20px;
    border-radius:12px; display:flex; align-items:center; gap:16px; font-size:13.5px;
    box-shadow:var(--shadow-lg); z-index:10001; animation:toastIn .25s ease;
}
@keyframes toastIn{ from{ opacity:0; transform:translateX(-50%) translateY(10px); } to{ opacity:1; transform:translateX(-50%) translateY(0); } }
.undo-toast button{
    all:unset; cursor:pointer; font-weight:700; color:var(--primary-hover); padding:4px 8px; border-radius:6px;
    background:rgba(255,255,255,.12); transition:var(--transition);
}
.undo-toast button:hover{ background:rgba(255,255,255,.2); }

/* ---------- Trash page ---------- */
.trash-header-row{ display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
.trash-header-row .settings-title{ margin-bottom:0; }
.trash-item{
    display:flex; align-items:center; justify-content:space-between; gap:12px;
