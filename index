function setSync(status) {
  const dot = document.getElementById('sync-dot');
  const text = document.getElementById('sync-text');
  dot.className = 'sync-dot' + (status === 'saving' ? ' saving' : status === 'error' ? ' error' : '');
  text.textContent = status === 'saving' ? 'Salvando...' : status === 'error' ? 'Erro ao salvar' : 'Conectado';
  if (status === 'saving') return;
  if (status !== 'error') setTimeout(() => { text.textContent = 'Conectado'; dot.className = 'sync-dot'; }, 800);
}

async function purgeOldTrash() {
  const cutoff = new Date(Date.now() - 30 * 86400000).toISOString();
