function selectBoardSwatch(el) {
  document.querySelectorAll('#new-board-swatches .swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
}

function slugify(name) {
  return 'custom_' + name.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '').slice(0, 30) + '_' + Date.now();
}

async function addBoardFromSettings() {
  const nameInput = document.getElementById('new-board-name');
  const name = nameInput.value.trim();
  if (!name) return;
  const selectedSwatch = document.querySelector('#new-board-swatches .swatch.selected');
  const color = selectedSwatch ? selectedSwatch.dataset.color : LABEL_PALETTE[0];
  const slug = slugify(name);
  setSync('saving');
  const { data, error } = await sb.from('boards').insert({ name, slug, color }).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  state.boards.push(data);
  state.columns[data.id] = [];
  state.cards[data.id] = [];
  state.labels[data.id] = [];
  const defaultCols = ['A Fazer', 'Fazendo', 'Feito'];
  const results = await Promise.all(defaultCols.map((n, i) => sb.from('columns').insert({ board_id: data.id, name: n, position: i }).select().single()));
  results.forEach(r => { if (r.data) state.columns[data.id].push(r.data); });
  setSync('ok');
  nameInput.value = '';
  renderTabs();
  render();
}

async function deleteBoardPrompt(boardId) {
  const board = state.boards.find(b => b.id === boardId);
  if (!board) return;
  if (state.boards.length <= 1) { alert('Você precisa manter pelo menos um quadro.'); return; }
  if (!confirm(`Excluir o quadro "${board.name}"? Ele vai para a lixeira por 30 dias, junto com tudo que tem dentro. Dá pra desfazer logo em seguida.`)) return;
  const now = new Date().toISOString();
  setSync('saving');
  const { error } = await sb.from('boards').update({ deleted_at: now }).eq('id', boardId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  board.deleted_at = now;
  state.boards = state.boards.filter(b => b.id !== boardId);
  delete state.columns[boardId];
  delete state.cards[boardId];
  delete state.labels[boardId];
  setSync('ok');
  if (state.view === boardId) { state.view = 'overview'; }
  renderTabs();
  render();
  showUndoToast(`Quadro "${board.name}" excluído`, async () => {
    setSync('saving');
    await sb.from('boards').update({ deleted_at: null }).eq('id', boardId);
    board.deleted_at = null;
    state.boards.push(board);
    const [{ data: columns }, { data: cards }, { data: labels }] = await Promise.all([
      sb.from('columns').select('*').eq('board_id', boardId).is('deleted_at', null).order('position'),
      sb.from('cards').select('*, card_labels(label_id), checklist_items(id, done), attachments(id), card_comments(id)').eq('board_id', boardId).is('deleted_at', null).order('position'),
      sb.from('labels').select('*').eq('board_id', boardId),
    ]);
    state.columns[boardId] = columns || [];
    state.cards[boardId] = cards || [];
    state.labels[boardId] = labels || [];
    setSync('ok');
    renderTabs();
    render();
  });
}

