}
.trash-item:last-child{ border-bottom:none; }
.trash-item-info{ display:flex; flex-direction:column; gap:2px; min-width:0; }
.trash-item-title{ font-size:14px; font-weight:600; color:var(--text); }
.trash-item-meta{ font-size:12px; font-weight:500; color:var(--text-muted); margin-left:4px; }
.trash-item-date{ font-size:12px; color:var(--text-muted); margin-top:2px; }
