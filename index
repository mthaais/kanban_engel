    await sb.from('cards').delete().lt('deleted_at', cutoff);
    await sb.from('columns').delete().lt('deleted_at', cutoff);
    await sb.from('boards').delete().lt('deleted_at', cutoff);
  } catch (e) { /* silencioso: limpeza automática não é crítica */ }
}

async function loadAll() {
