<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kanban Família Engel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://unpkg.com/@supabase/supabase-js@2"></script>
<style>
/*
===============================================
KANBAN MODERN UI
Versão: 1.0
Inspirado em:
- Trello
- ClickUp
- Linear
- Notion

Criado para:
Kanban Família Engel
===============================================
*/

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

:root{
    /* ===== PRIMARY ===== */
    --primary:#5B7CFA;
    --primary-hover:#4868E7;
    --primary-active:#3A54C4;
    --primary-disabled:#C2CDF8;

    /* ===== NEUTRALS / SURFACES ===== */
    --bg:#F6F8FC;
    --surface:#FFFFFF;
    --surface-2:#FAFBFD;
    --surface-3:#F2F5FA;
    --surface-elevation-1: var(--surface);
    --surface-elevation-2: var(--surface-2);
    --surface-elevation-3: var(--surface-3);
    --card-bg: var(--surface);
    --border:#E5EAF2;
    --border-hover:#D6DEE8;
    --divider:#EDEFF5;
    --hover-bg: rgba(15,23,42,.035);
    --overlay: rgba(15,23,42,.35);

    /* ===== TEXT LEVELS ===== */
    --text:#23272F;
    --text-secondary:#4B5568;
    --text-light:#697586;
    --text-muted:#9AA5B1;
    --text-disabled:#C3CAD6;
    --text-placeholder:#ADB5C4;
    --text-inverse:#FFFFFF;

    /* ===== STATES: SUCCESS / WARNING / DANGER / INFO / NEUTRAL ===== */
    --success:#1FA463; --success-bg:#E6F7EF; --success-border:#A9E4C6; --success-hover:#178F55;
    --warning:#D98A1A; --warning-bg:#FDF3E2; --warning-border:#F3D48F; --warning-hover:#BC7712;
    --danger:#E5484D;  --danger-bg:#FCEBEC;  --danger-border:#F5B8BA;  --danger-hover:#C93A3F;
    --info:#2E7BD6;    --info-bg:#E8F1FC;    --info-border:#A9CDF0;    --info-hover:#1F63B0;
    --neutral:#6B7280; --neutral-bg:#F1F2F5; --neutral-border:#D8DCE3; --neutral-hover:#565D6B;

    /* ===== KANBAN / LABEL PALETTE (9 cores) — cada uma com main / light / dark ===== */
    --blue:#4C6EF5;      --blue-light:#E3E8FF;      --blue-dark:#2E45B8;
    --purple:#8B5CF6;    --purple-light:#EDE4FF;    --purple-dark:#5B32C9;
    --pink:#EC4899;      --pink-light:#FCE1EE;      --pink-dark:#B22D6C;
    --red:#EF4444;       --red-light:#FCE4E4;       --red-dark:#B32323;
    --orange:#F97316;    --orange-light:#FEE9D6;    --orange-dark:#B85A0F;
    --yellow:#EAB308;    --yellow-light:#FBF0CE;    --yellow-dark:#9C7A05;
    --green:#22C55E;     --green-light:#DDF5E6;     --green-dark:#157A3D;
    --turquoise:#14B8A6; --turquoise-light:#D7F5F1; --turquoise-dark:#0D7A6E;
    --gray:#64748B;      --gray-light:#E7EAEF;      --gray-dark:#3F4A5C;

    /* ===== GLASS / OVERLAY (usados em sidebar, colunas e botões translúcidos) ===== */
    --sidebar-bg: rgba(255,255,255,.72);
    --column-bg: rgba(255,255,255,.70);
    --glass-btn-bg: rgba(255,255,255,.85);
    --glass-btn-bg-soft: rgba(255,255,255,.45);

    /* ===== SHADOWS ===== */
    --shadow-xs: 0 1px 2px rgba(0,0,0,.03);
    --shadow-sm: 0 4px 12px rgba(15,23,42,.05);
    --shadow-md: 0 10px 24px rgba(15,23,42,.08);
    --shadow-lg: 0 18px 45px rgba(15,23,42,.14);
    --shadow-xl: 0 30px 70px rgba(15,23,42,.18);

    /* ===== OPACITY TOKENS ===== */
    --opacity-glass: .70;
    --opacity-overlay: .35;
    --opacity-hover: .06;
    --opacity-focus: .15;
    --opacity-dropdown-shadow: .18;
    --opacity-modal-shadow: .18;
    --opacity-tooltip-bg: .92;

    /* ===== RADIUS / MOTION ===== */
    --radius-xs:8px;
    --radius-sm:12px;
    --radius-md:16px;
    --radius-lg:20px;
    --radius-xl:28px;
    --transition:.25s cubic-bezier(.2,.8,.2,1);
}

*{ margin:0; padding:0; box-sizing:border-box; }
html{ scroll-behavior:smooth; }
body{
    font-family:'Inter',sans-serif;
    background:
      radial-gradient(circle at 12% -8%, rgba(76,110,245,.07), transparent 42%),
      radial-gradient(circle at 100% 0%, rgba(201,124,109,.09), transparent 42%),
      radial-gradient(circle at 100% 100%, rgba(34,197,94,.05), transparent 42%),
      var(--bg);
    background-attachment:fixed;
    color:var(--text);
    -webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;
}
body.dark{
    background:
      radial-gradient(circle at 12% -8%, rgba(107,140,255,.10), transparent 45%),
      radial-gradient(circle at 100% 0%, rgba(201,124,109,.12), transparent 45%),
      radial-gradient(circle at 100% 100%, rgba(61,214,140,.07), transparent 45%),
      var(--bg);
    background-attachment:fixed;
}

::-webkit-scrollbar{ width:10px; height:10px; }
::-webkit-scrollbar-track{ background:transparent; }
::-webkit-scrollbar-thumb{ background:#CFD8E3; border-radius:30px; transition:.2s; }
::-webkit-scrollbar-thumb:hover{ background:#B7C2CF; }

a{ color:inherit; text-decoration:none; }
button{ font-family:inherit; transition:var(--transition); }
input, textarea, select{ font-family:inherit; }

main{ max-width:1400px; margin:0 auto; padding-bottom:80px; flex: 1; min-width: 0; }

.app-shell{ display:flex; min-height:100vh; align-items:flex-start; }

.sidebar{
    width:240px; flex-shrink:0;
    background:var(--sidebar-bg);
    backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);
    border-right:1px solid var(--border);
    height:100vh; position:sticky; top:0;
    display:flex; flex-direction:column;
    padding:24px 14px;
}
.sidebar-brand{ padding:6px 10px 22px; }
.sidebar-brand h1{ font-size:17px; font-weight:700; letter-spacing:-0.02em; color:var(--text); line-height:1.3; }

.sidebar-nav{ display:flex; flex-direction:column; gap:3px; flex:1; overflow-y:auto; }
.sidebar-nav button{
    all:unset; cursor:pointer; display:flex; align-items:center; gap:11px;
    padding:10px 10px 10px 9px; border-radius:12px; color:var(--text-light);
    font-size:14px; font-weight:600; transition:var(--transition);
    border-left:3px solid transparent; white-space:nowrap;
}
.sidebar-nav button:hover{ background:var(--surface-3); color:var(--text); }
.sidebar-nav button.active{ background:var(--surface-3); color:var(--text); border-left-color:var(--tab-color,var(--primary)); }
.sidebar-icon{
    width:26px; height:26px; border-radius:8px; flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
    background:var(--surface-3); color:var(--text-light);
}
.sidebar-icon svg{ width:15px; height:15px; stroke:currentColor; }

.sidebar-footer{ display:flex; flex-direction:column; gap:10px; padding:14px 10px 4px; border-top:1px solid var(--border); margin-top:10px; }

.user-badge{
    background:var(--surface); border:1px solid var(--border); border-radius:999px;
    padding:9px 14px; box-shadow:var(--shadow-xs); cursor:pointer; transition:var(--transition);
    font-size:13px; text-align:left; width: 100%;
}
.user-badge:hover{ transform:translateY(-2px); box-shadow:var(--shadow-sm); }

.sync-status{ display:flex; align-items:center; gap:8px; font-size:12.5px; color:var(--text-light); padding:0 4px; }
.sync-dot{ width:9px; height:9px; border-radius:50%; background:#32D583; box-shadow: 0 0 8px rgba(50,213,131,.4); flex-shrink:0; }
.sync-dot.saving{ background:#FDB022; }
.sync-dot.error{ background:#F04438; }

.board-inner{ padding:32px; }

.filter-bar{ display:flex; margin-bottom:22px; }
.filter-trigger-btn{
    all:unset; cursor:pointer; display:flex; align-items:center; gap:8px;
    padding:9px 16px; border-radius:10px; background:var(--surface); border:1px solid var(--border);
    color:var(--text-light); font-size:13.5px; font-weight:600; transition:var(--transition);
    box-shadow:var(--shadow-xs);
}
.filter-trigger-btn:hover{ border-color:var(--border-hover); color:var(--text); }
.filter-trigger-btn.active{ border-color:var(--primary); color:var(--primary); background:rgba(91,124,250,.14); }
.filter-trigger-badge{
    display:inline-flex; align-items:center; justify-content:center; min-width:18px; height:18px;
    padding:0 5px; border-radius:999px; background:var(--primary); color:white; font-size:11px; font-weight:700;
}
.filter-trigger-badge:empty{ display:none; }

.filter-popover{ width:300px; max-height:70vh; }
.filter-popover-body{ overflow-y:auto; }
.filter-group{ margin-bottom:16px; }
.filter-group-label{ font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:.05em; color:var(--text-muted); margin-bottom:8px; }
.filter-checkbox-row{
    display:flex; align-items:center; gap:9px; padding:7px 4px; font-size:13.5px; color:var(--text);
    cursor:pointer; border-radius:8px; transition:var(--transition);
}
.filter-checkbox-row:hover{ background:var(--surface-3); }
.filter-checkbox-row input[type=checkbox]{ width:16px; height:16px; accent-color:var(--primary); flex-shrink:0; }
.filter-icon{ font-size:14px; flex-shrink:0; }
.filter-label-pill{ font-size:12px; font-weight:700; padding:4px 10px; border-radius:6px; }
.filter-hint{ font-size:11.5px; color:var(--text-muted); margin-top:4px; }
.filter-popover .popover-search{ margin-bottom:0; }

.board-banner{
    position:relative; overflow:hidden; display:flex; align-items:center; gap:14px;
    padding:16px 24px; margin-bottom:24px; border-radius:18px; min-height:auto;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark));
    box-shadow: 0 10px 26px rgba(0,0,0,.10);
}
.board-banner::before{ content:""; position:absolute; width:220px; height:220px; right:-90px; top:-100px; border-radius:50%; background: rgba(255,255,255,.10); }
.board-banner::after{ content:""; position:absolute; width:120px; height:120px; bottom:-60px; left:-30px; border-radius:50%; background: rgba(255,255,255,.08); }
.board-banner .icon{ width:40px; height:40px; border-radius:12px; background: rgba(255,255,255,.18); display:flex; justify-content:center; align-items:center; backdrop-filter:blur(10px); z-index:2; flex-shrink:0; }
.board-banner .icon svg{ width:20px; height:20px; stroke:white; }
.board-banner h1{ color:white; font-size:20px; font-weight:700; margin-bottom:2px; position:relative; z-index:2; }
.board-banner .subtitle{ color:rgba(255,255,255,.85); font-size:13px; opacity:.85; position:relative; z-index:2; }

.overview-wrap{ padding:32px; }
.overview-board{ margin-bottom:42px; }

.overview-board-header{
    display:flex; align-items:center; gap:18px; background:var(--surface); border-radius:20px;
    padding:18px 22px; border:1px solid var(--border); box-shadow:var(--shadow-sm);
    cursor:pointer; transition:var(--transition);
}
.overview-board-header:hover{ transform:translateY(-3px); box-shadow:var(--shadow-md); }
.overview-board-header .icon{
    width:52px; height:52px; border-radius:16px; display:flex; align-items:center; justify-content:center;
    background: linear-gradient(135deg, var(--accent), var(--accent-dark)); color:white;
}
.overview-board-header .icon svg{ width:24px; height:24px; stroke:white; }
.overview-board-header h2{ font-size:18px; font-weight:700; color:var(--text); }
.overview-board-header .go{ margin-left:auto; color:var(--text-light); font-size:13px; font-weight:600; }

.mini-columns{ display:flex; gap:18px; overflow-x:auto; padding-top:18px; padding-bottom:10px; }
.mini-column{ width:260px; flex-shrink:0; }
.mini-column .name{ font-size:12px; font-weight:700; letter-spacing:.08em; color:var(--text-muted); text-transform:uppercase; margin-bottom:12px; padding-left:4px; }

.mini-card{
    background:var(--surface); border:none; border-radius:16px;
    padding:0; margin-bottom:10px; box-shadow:var(--shadow-xs); transition:var(--transition);
    overflow:hidden;
}
.mini-card:hover{ transform: translateY(-3px); box-shadow:var(--shadow-md); }
.mini-card-content{ padding:10px 12px; }
.mini-card .meta-row{ margin-top:8px; }

.board-columns{ display:flex; align-items:flex-start; gap:22px; overflow-x:auto; padding-bottom:20px; padding-top:4px; }

.column{
    width:310px; min-height:120px; flex-shrink:0; display:flex; flex-direction:column;
    border-radius:22px; background:var(--column-bg);
    backdrop-filter:blur(12px); -webkit-backdrop-filter:blur(12px);
    border:1px solid rgba(255,255,255,.55);
    box-shadow: 0 10px 35px rgba(15,23,42,.05);
    transition:var(--transition);
    position:relative;
}
.column:hover{ transform:translateY(-2px); }
.column.drag-over{ border:2px dashed var(--primary); box-shadow: 0 0 0 6px rgba(91,124,250,.08); }

.column-header{ display:flex; align-items:center; justify-content:space-between; padding:18px 18px 8px; background:transparent; border:none; border-bottom:1px solid rgba(0,0,0,.06); margin:0; }
.column-header-right{ display:flex; align-items:center; gap:8px; }
.column-header .name{ font-size:13px; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--accent-dark); }
.column-header .count{
    background:var(--surface-3); color:var(--text); min-width:28px; height:28px; padding:0 10px;
    border-radius:999px; display:flex; align-items:center; justify-content:center;
    font-size:12px; font-weight:700; border:1px solid var(--border); box-shadow:var(--shadow-xs);
}

.col-menu-btn{
    all:unset; cursor:pointer; width:32px; height:32px; border-radius:10px; display:flex;
    align-items:center; justify-content:center; color:var(--text-light); transition:var(--transition);
}
.col-menu-btn:hover{ background:var(--surface-3); box-shadow:var(--shadow-xs); color:var(--text); }

.card-list{ padding: 0 14px 14px; min-height:40px; }

.empty-hint{ background:var(--surface); border:2px dashed var(--border); border-radius:16px; padding:20px; color:var(--text-muted); font-size:13px; text-align:center; }

.card{
    background:var(--surface); border:none; border-radius:16px; padding:0; margin-bottom:14px;
    cursor:grab; position:relative; overflow:hidden;
    box-shadow: 0 8px 20px rgba(15,23,42,.06);
    transition: transform .25s, box-shadow .25s, opacity .25s;
    touch-action: none; -webkit-touch-callout: none; user-select: none;
}
.card::after{
    content:""; position:absolute; top:-120%; left:-40%; width:40px; height:220%;
    transform:rotate(25deg); background: rgba(255,255,255,.35); transition:.7s; pointer-events:none;
}
.card:hover::after{ left:130%; }
.card:hover{ transform: translateY(-5px) scale(1.015); box-shadow: 0 18px 38px rgba(15,23,42,.13); }
.card:active{ cursor:grabbing; }
.card.dragging{ opacity:.35; }

.card-ghost{ position:fixed; pointer-events:none; z-index:9999; border-radius:16px; box-shadow: 0 25px 55px rgba(0,0,0,.25); overflow:hidden; }

.card-menu-btn{
    all:unset; cursor:pointer; position:absolute; top:8px; right:8px; z-index:2;
    width:22px; height:22px; display:flex; align-items:center; justify-content:center;
    border-radius:6px; color:var(--text-light); font-weight:700; font-size:14px; line-height:1;
    background:var(--glass-btn-bg); opacity:.5; transition:opacity .15s ease, background .15s ease;
}
.card:hover .card-menu-btn{ opacity:1; }
.card-menu-btn:hover{ background:var(--surface-3); color:var(--text); }

.card-label-bar{ height:6px; width:100%; flex-shrink:0; }
.card-content{ padding:12px 14px; }

.card .title{ font-size:15px; font-weight:700; color:var(--text); line-height:1.5; }

.card .meta-row{ display:flex; flex-wrap:wrap; gap:8px; margin-top:12px; }

.meta-pill{
    display:flex; align-items:center; gap:6px; padding: 6px 10px; border-radius:999px;
    background: var(--surface-3); font-size:12px; font-weight:600; color:var(--text-light);
}
.meta-pill.due-pill{ background:var(--warning-bg); color:var(--warning-hover); }
.meta-pill.due-pill.overdue{ background:var(--danger-bg); color:var(--danger-hover); }

.add-card-btn{
    all:unset; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px;
    margin: 4px 14px 14px; padding:14px; border-radius:14px; border:2px dashed var(--border);
    background:var(--surface); color:var(--text-light); font-weight:600; transition:var(--transition);
}
.add-card-btn:hover{ border-color:var(--primary); background:var(--surface-2); color:var(--primary); }

.add-column-btn{
    all:unset; cursor:pointer; width:280px; flex-shrink:0; padding:22px; border-radius:22px;
    border:2px dashed var(--border); background:var(--glass-btn-bg-soft); backdrop-filter:blur(10px);
    color:var(--text-light); font-weight:700; transition:var(--transition); height: fit-content;
}
.add-column-btn:hover{ background:var(--surface); transform:translateY(-4px); box-shadow:var(--shadow-md); border-color:var(--primary); color:var(--primary); }

.column-menu{
    position:fixed; border:none; border-radius:18px; padding:10px;
    background:var(--surface); box-shadow: 0 25px 60px rgba(15,23,42,.18);
    display:flex; flex-direction:column; min-width:200px; z-index:10000;
    animation:dropdownOpen .18s ease; transform-origin:top right;
}
.column-menu button{ all:unset; box-sizing:border-box; cursor:pointer; padding:10px 14px; border-radius:12px; transition:var(--transition); display:flex; align-items:center; gap:10px; width:100%; font-size:13px; font-weight:600; text-align:left; color:var(--text); }
.column-menu button:hover{ background:var(--surface-3); }
.column-menu button.danger{ color:var(--danger); }
.column-menu-divider{ height:1px; margin:10px 0; background:var(--border); }
.column-menu-label{ padding:6px 12px; color:var(--text-muted); text-transform:uppercase; font-size:11px; letter-spacing:.08em; }

.column-menu-swatches{ display:flex; flex-wrap:wrap; gap:10px; padding:10px 12px; }
.column-menu-swatches .swatch{ width:24px; height:24px; transition:var(--transition); }
.column-menu-swatches .swatch:hover{ transform:scale(1.18); }
.column-menu-swatches .swatch.selected{ border:3px solid white; box-shadow: 0 0 0 2px var(--text); }

.modal-backdrop{
    position:fixed; inset:0; display:flex; justify-content:center; align-items:flex-start;
    overflow-y:auto; padding:40px 20px; background:rgba(15,23,42,.35);
    backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px);
    animation:fadeBackdrop .25s ease; z-index:9999;
}

.modal{
    width:90vw; max-width:900px; background:var(--surface); border-radius:20px; padding:0;
    border:1px solid rgba(255,255,255,.65); box-shadow: 0 30px 70px rgba(15,23,42,.18);
    animation:modalOpen .28s ease;
    display:flex; flex-direction:row; position:relative;
    max-height:85vh;
}

.card-modal-main{ flex:3; padding:26px; overflow-y:auto; max-height:85vh; min-width:0; }
.card-modal-sidebar{
    flex:2; min-width:280px; border-left:1px solid var(--border); padding:22px; background:var(--surface-2);
    overflow-y:auto; max-height:85vh; display:flex; flex-direction:column;
    border-radius:0 20px 20px 0;
}

@media (max-width:768px){
    .modal{ flex-direction:column; width:94vw; max-width:94vw; max-height:88vh; }
    .card-modal-main{ max-height:none; }
    .card-modal-sidebar{ border-left:none; border-top:1px solid var(--border); max-height:none; border-radius:0 0 20px 20px; }
}

.modal-close{
    all:unset; width:34px; height:34px; display:flex; align-items:center; justify-content:center;
    cursor:pointer; border-radius:10px; color:var(--text-light); transition:var(--transition);
    position:absolute; top:14px; right:14px; z-index:5; background:var(--surface);
}
.modal-close:hover{ background:var(--surface-3); color:var(--text); }

.modal .title-input{
    width:100%; border:none; background:transparent; font-size:21px; font-weight:700;
    color:var(--text); margin-bottom:6px; letter-spacing:-0.5px; padding: 4px 0;
}
.modal .title-input:focus{ outline:none; }
.modal .title-input::placeholder{ color:#B4BDC9; }

.card-authorship{
    display:inline-flex; align-items:center; gap:8px; padding:5px 12px; border-radius:999px;
    background:var(--surface-3); color:var(--text-light); font-size:12px; margin-bottom:16px;
}

.modal-section{ margin-top:20px; }
.section-label{ font-size:11px; text-transform:uppercase; letter-spacing:.10em; color:var(--text-muted); font-weight:700; margin-bottom:8px; }
.section-hint{ color:var(--text-light); font-size:12.5px; margin-bottom:8px; }

.modal input[type=text], .modal input[type=date], .modal textarea, .modal select{
    width:100%; border:1px solid var(--border); background:var(--surface-2); border-radius:12px;
    padding:10px 13px; font-size:13.5px; transition:var(--transition);
}
.modal textarea{ min-height:70px; resize:vertical; }
.modal input:focus, .modal textarea:focus, .modal select:focus{
    outline:none; border-color:var(--primary); background:var(--surface); box-shadow: 0 0 0 4px rgba(91,124,250,.12);
}

.inline-add{ display:flex; gap:12px; margin-top:12px; }
.inline-add input{ flex:1; }
.inline-add button, .modal-primary-btn{
    all:unset; cursor:pointer; background:var(--primary); color:white; padding:13px 22px;
    border-radius:14px; font-weight:700; transition:var(--transition); text-align:center;
}
.inline-add button:hover, .modal-primary-btn:hover{ background:var(--primary-hover); transform:translateY(-2px); box-shadow:var(--shadow-md); }

.checklist-progress-row{ display:flex; align-items:center; gap:12px; margin-bottom:16px; }
