}
.file-upload-label:hover{ border-color:var(--primary); color:var(--primary); background:#F7F9FF; }

@keyframes modalOpen{ from{ opacity:0; transform: translateY(25px) scale(.96); } to{ opacity:1; transform: translateY(0) scale(1); } }
