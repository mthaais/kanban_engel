async function loadTrashContent() {
  const container = document.getElementById('trash-content');
  if (!container) return;
  const [{ data: deletedBoards, error: boardErr }, { data: deletedColumns, error: colErr }, { data: deletedCards, error: cardErr }] = await Promise.all([
    sb.from('boards').select('*').not('deleted_at', 'is', null).order('deleted_at', { ascending: false }),
    sb.from('columns').select('*, boards(name)').not('deleted_at', 'is', null).order('deleted_at', { ascending: false }),
    sb.from('cards').select('*, boards(name)').not('deleted_at', 'is', null).order('deleted_at', { ascending: false }),
  ]);
  if (boardErr || colErr || cardErr) {
    container.innerHTML = `<div class="empty-state">Erro ao carregar a lixeira.</div>`;
    return;
  }
  if (!deletedBoards.length && !deletedColumns.length && !deletedCards.length) {
    container.innerHTML = `<div class="empty-state">A lixeira está vazia.</div>`;
    return;
  }
  const boardsHtml = deletedBoards.map(b => `
    <div class="trash-item">
      <div class="trash-item-info">
        <div class="trash-item-title">🗃 ${escapeHtml(b.name)} <span class="trash-item-meta">quadro</span></div>
        <div class="trash-item-date">Excluído ${formatCommentTime(b.deleted_at)}</div>
      </div>
      <div class="trash-item-actions">
        <button class="modal-primary-btn" onclick="restoreBoardFromTrash('${b.id}')">Restaurar</button>
        <button class="delete-card-btn" onclick="purgeBoardNow('${b.id}')">Excluir definitivamente</button>
      </div>
    </div>`).join('');
  const columnsHtml = deletedColumns.map(c => `
    <div class="trash-item">
      <div class="trash-item-info">
        <div class="trash-item-title">📋 ${escapeHtml(c.name)} <span class="trash-item-meta">coluna · ${escapeHtml(c.boards?.name || '')}</span></div>
        <div class="trash-item-date">Excluída ${formatCommentTime(c.deleted_at)}</div>
      </div>
      <div class="trash-item-actions">
        <button class="modal-primary-btn" onclick="restoreColumnFromTrash('${c.id}')">Restaurar</button>
        <button class="delete-card-btn" onclick="purgeColumnNow('${c.id}')">Excluir definitivamente</button>
      </div>
    </div>`).join('');
  const cardsHtml = deletedCards.map(c => `
    <div class="trash-item">
      <div class="trash-item-info">
        <div class="trash-item-title">🗂 ${escapeHtml(c.title)} <span class="trash-item-meta">card · ${escapeHtml(c.boards?.name || '')}</span></div>
        <div class="trash-item-date">Excluído ${formatCommentTime(c.deleted_at)}</div>
      </div>
      <div class="trash-item-actions">
        <button class="modal-primary-btn" onclick="restoreCardFromTrash('${c.id}')">Restaurar</button>
        <button class="delete-card-btn" onclick="purgeCardNow('${c.id}')">Excluir definitivamente</button>
      </div>
    </div>`).join('');
  container.innerHTML = boardsHtml + columnsHtml + cardsHtml;
}

async function restoreCardFromTrash(cardId) {
  setSync('saving');
  const { data, error } = await sb.from('cards').update({ deleted_at: null }).eq('id', cardId).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  if (state.cards[data.board_id] && !state.cards[data.board_id].some(c => c.id === cardId)) {
    data.card_labels = data.card_labels || [];
    data.checklist_items = data.checklist_items || [];
    data.attachments = data.attachments || [];
    data.card_comments = data.card_comments || [];
    data.assignees = data.assignees || [];
    state.cards[data.board_id].push(data);
  }
  setSync('ok');
  loadTrashContent();
}

async function restoreColumnFromTrash(columnId) {
  setSync('saving');
  const { data: colRow, error: fetchErr } = await sb.from('columns').select('*').eq('id', columnId).single();
  if (fetchErr || !colRow) { setSync('error'); return; }
  const ts = colRow.deleted_at;
  const { error } = await sb.from('columns').update({ deleted_at: null }).eq('id', columnId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  const { data: cardsToRestore } = await sb.from('cards').select('*').eq('column_id', columnId).eq('deleted_at', ts);
  if (cardsToRestore && cardsToRestore.length) {
    await Promise.all(cardsToRestore.map(c => sb.from('cards').update({ deleted_at: null }).eq('id', c.id)));
  }
  colRow.deleted_at = null;
  if (state.columns[colRow.board_id] && !state.columns[colRow.board_id].some(c => c.id === columnId)) {
    state.columns[colRow.board_id].push(colRow);
  }
  (cardsToRestore || []).forEach(c => {
    c.deleted_at = null;
    c.card_labels = []; c.checklist_items = []; c.attachments = []; c.card_comments = []; c.assignees = c.assignees || [];
    if (state.cards[c.board_id] && !state.cards[c.board_id].some(existing => existing.id === c.id)) {
      state.cards[c.board_id].push(c);
    }
  });
  setSync('ok');
  loadTrashContent();
}

