/* ---------- Card modal ---------- */
function findCard(cardId) {
  for (const boardId in state.cards) {
    const card = state.cards[boardId].find(c => c.id === cardId);
    if (card) return { card, boardId };
  }
  return null;
}

async function openCard(cardId) {
  state.openCardId = cardId;
  const found = findCard(cardId);
  if (!found) return;
  const { card, boardId } = found;

  const [{ data: fullCard }, { data: checklist }, { data: attachments }, { data: comments }] = await Promise.all([
    sb.from('cards').select('*, card_labels(label_id)').eq('id', cardId).single(),
    sb.from('checklist_items').select('*').eq('card_id', cardId).order('position'),
    sb.from('attachments').select('*').eq('card_id', cardId).order('created_at'),
    sb.from('card_comments').select('*').eq('card_id', cardId).order('created_at'),
  ]);
  card.description = fullCard.description;
  card.due_date = fullCard.due_date;
  card.card_labels = fullCard.card_labels;
  card.assignees = fullCard.assignees || [];
  card.checklist_items = checklist || [];
  card.attachments = attachments || [];
  card.card_comments = comments || [];

  renderModal(boardId, card);
}

function closeModal() {
  const el = document.getElementById('modal-backdrop');
  if (el) el.remove();
  state.openCardId = null;
  render();
  if (pendingRemoteRefresh) {
    pendingRemoteRefresh = false;
    refreshData();
  }
}

function renderModal(boardId, card) {
  const existing = document.getElementById('modal-backdrop');
  if (existing) existing.remove();
  closeLabelPopover();
  closeCardContextMenu();

  const checklist = card.checklist_items || [];
  const doneCount = checklist.filter(c => c.done).length;
  const progressPct = checklist.length ? Math.round((doneCount / checklist.length) * 100) : 0;
  const checklistHtml = checklist.map(item => `
    <div class="checklist-item">
      <input type="checkbox" ${item.done ? 'checked' : ''} onchange="toggleChecklistItem('${item.id}','${card.id}',this.checked)">
      <span class="${item.done ? 'done' : ''}">${escapeHtml(item.text)}</span>
      <button class="del-btn" onclick="deleteChecklistItem('${item.id}','${card.id}')">×</button>
    </div>
  `).join('');

  const attachmentsHtml = (card.attachments || []).map(a => `
    <div class="attachment-item">
      <a href="${a.file_url}" target="_blank" rel="noopener">${escapeHtml(a.file_name)}</a>
      <button class="del-btn" onclick="deleteAttachment('${a.id}','${card.id}')">×</button>
    </div>
  `).join('');

  const assignees = card.assignees || [];
  const assigneesHtml = assignees.map((name, idx) => `
    <span class="assignee-chip">
      <span class="avatar">${escapeHtml(initials(name))}</span>${escapeHtml(name)}
      <button class="remove-btn" onclick="removeAssignee('${card.id}','${boardId}',${idx})">×</button>
    </span>
  `).join('');

  const comments = card.card_comments || [];
  const commentsHtml = comments.length
    ? comments.map(c => `
      <div class="comment-item">
        <div class="comment-avatar">${escapeHtml(initials(c.author))}</div>
        <div class="comment-body">
          <div class="comment-meta"><span class="comment-author">${escapeHtml(c.author)}</span><span class="comment-time">${formatCommentTime(c.created_at)}</span></div>
          <div class="comment-text">${escapeHtml(c.text)}</div>
        </div>
      </div>
    `).join('')
    : `<div class="comment-empty">Nenhum comentário ainda.</div>`;

  const html = `
  <div class="modal-backdrop" id="modal-backdrop" onclick="if(event.target===this) closeModal()">
    <div class="modal">
      <button class="modal-close" onclick="closeModal()">×</button>
      <div class="card-modal-main">
        <input class="title-input" type="text" value="${escapeHtml(card.title)}" onblur="updateCardField('${card.id}','title',this.value)">
        ${(card.created_by || card.updated_by) ? `<div class="card-authorship">${card.created_by ? `Criado por ${escapeHtml(card.created_by)}` : ''}${card.created_by && card.updated_by && card.updated_by !== card.created_by ? ` · Editado por ${escapeHtml(card.updated_by)}` : ''}</div>` : ''}

        <div class="modal-section">
          <div class="section-label">Descrição</div>
          <textarea placeholder="Adicionar descrição..." onblur="updateCardField('${card.id}','description',this.value)">${escapeHtml(card.description || '')}</textarea>
        </div>

        <div class="modal-section">
          <div class="section-label">Etiquetas</div>
          <div class="label-chips-row" id="label-chips-row">${renderLabelChipsInner(card.id, boardId)}</div>
        </div>

        <div class="modal-section">
          <div class="section-label">Checklist</div>
          ${checklist.length ? `<div class="checklist-progress-row"><span>${progressPct}%</span><div class="checklist-progress-bar"><div class="fill" style="width:${progressPct}%"></div></div></div>` : ''}
          ${checklistHtml}
          <div class="inline-add">
            <input type="text" id="new-checklist-item" placeholder="Adicionar item...">
            <button onclick="addChecklistItem('${card.id}')">Adicionar</button>
          </div>
        </div>

        <div class="modal-section">
          <div class="section-label">Data de vencimento</div>
          <input type="date" value="${card.due_date || ''}" onchange="updateCardField('${card.id}','due_date',this.value)">
        </div>

        <div class="modal-section">
          <div class="section-label">Responsáveis</div>
          <div class="assignee-list">${assigneesHtml}</div>
          <div class="inline-add">
            <input type="text" id="new-assignee-name" placeholder="Nome da pessoa..." onkeydown="if(event.key==='Enter'){event.preventDefault();addAssignee('${card.id}','${boardId}');}">
            <button onclick="addAssignee('${card.id}','${boardId}')">Adicionar</button>
          </div>
        </div>

        <div class="modal-section">
          <div class="section-label">Anexos</div>
          ${attachmentsHtml}
          <label class="file-upload-label" style="margin-top:8px;">
            Enviar arquivo...
            <input type="file" style="display:none" onchange="uploadAttachment(event,'${card.id}')">
          </label>
        </div>

        <div class="modal-footer">
          <button class="delete-card-btn" onclick="deleteCard('${card.id}','${boardId}')">Excluir card</button>
        </div>
      </div>

      <div class="card-modal-sidebar">
        <div class="section-label">Comentários e atividade</div>
        <div class="comment-list">${commentsHtml}</div>
        <div class="comment-composer">
          <textarea id="new-comment-text" placeholder="Escrever um comentário..." rows="3" onkeydown="if((event.key==='Enter')&&(event.metaKey||event.ctrlKey)){event.preventDefault();addComment('${card.id}','${boardId}');}"></textarea>
          <button class="modal-primary-btn" onclick="addComment('${card.id}','${boardId}')">Comentar</button>
        </div>
      </div>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', html);
}

async function updateCardField(cardId, field, value) {
  const found = findCard(cardId);
  if (!found) return;
  const userName = ensureUserName();
  found.card[field] = value || null;
  found.card.updated_by = userName;
  setSync('saving');
  const { error } = await sb.from('cards').update({ [field]: value || null, updated_by: userName }).eq('id', cardId);
  if (error) { setSync('error'); return; }
  setSync('ok');
  render();
}

function refreshLabelUI(cardId, boardId) {
  const popoverList = document.getElementById('label-popover-list');
  if (popoverList) popoverList.innerHTML = renderLabelPopoverList(cardId, boardId);
  const chipsRow = document.getElementById('label-chips-row');
  if (chipsRow) chipsRow.innerHTML = renderLabelChipsInner(cardId, boardId);
  if (state.view === boardId) {
    renderBoardColumns(state.boards.find(b => b.id === boardId));
  } else if (state.view === 'overview') {
    render();
  }
}

function renderLabelChipsInner(cardId, boardId) {
  const found = findCard(cardId);
  if (!found) return '';
  const labels = state.labels[boardId] || [];
  const selectedIds = (found.card.card_labels || []).map(cl => cl.label_id);
  const chips = selectedIds.map(id => {
    const l = labels.find(x => x.id === id);
    if (!l) return '';
    return `<span class="label-pill" style="background:${l.color};color:${contrastText(l.color)}">${escapeHtml(l.name)}</span>`;
  }).join('');
  return `${chips}<button class="add-label-btn" title="Adicionar etiqueta" onpointerdown="event.stopPropagation()" onclick="event.stopPropagation();const r=this.getBoundingClientRect();showLabelPopover(r.left,r.bottom+6,'${cardId}','${boardId}')">+</button>`;
}

function renderLabelPopoverList(cardId, boardId) {
  const found = findCard(cardId);
  if (!found) return '';
  const labels = state.labels[boardId] || [];
  const selectedIds = (found.card.card_labels || []).map(cl => cl.label_id);
  const search = (state.labelPopoverSearch || '').toLowerCase();
  const filtered = labels.filter(l => !search || l.name.toLowerCase().includes(search));
  if (!filtered.length) return `<div class="comment-empty">Nenhuma etiqueta encontrada.</div>`;
  return filtered.map(l => {
    if (state.editingLabelId === l.id) {
      const draft = state.editLabelDraft;
      const swatches = LABEL_PALETTE.map(c => `<button class="swatch ${draft.color === c ? 'selected' : ''}" style="background:${c}" onclick="setEditLabelColor('${c}')"></button>`).join('');
      return `<div class="label-row-item editing">
        <input type="text" class="label-edit-name" value="${escapeHtml(draft.name)}" oninput="state.editLabelDraft.name=this.value">
        <div class="swatch-row">${swatches}</div>
        <div class="label-edit-actions">
          <button onclick="saveLabelEdit('${boardId}','${l.id}')">Salvar</button>
          <button class="danger" onclick="deleteLabel('${boardId}','${l.id}','${cardId}')">Excluir</button>
          <button onclick="cancelLabelEdit('${boardId}','${cardId}')">Cancelar</button>
        </div>
      </div>`;
    }
    const checked = selectedIds.includes(l.id);
    const tooltip = `Cor: ${colorName(l.color)}, título: '${escapeHtml(l.name)}'`;
    return `<div class="label-row-item ${checked ? '' : 'unselected'}" style="background:${l.color};color:${contrastText(l.color)}" title="${tooltip}" onclick="toggleLabel('${cardId}','${l.id}','${boardId}')">
      <span class="label-check">${checked ? '✓' : ''}</span>
      <span class="label-name">${escapeHtml(l.name)}</span>
      <button class="label-edit-btn" style="color:${contrastText(l.color)}" onclick="event.stopPropagation();startEditLabel('${l.id}','${boardId}','${cardId}')">✎</button>
    </div>`;
  }).join('');
}

function showLabelPopover(x, y, cardId, boardId) {
  closeCardContextMenu();
  closeLabelPopover();
  state.labelPopoverSearch = '';
  state.labelPopoverCtx = { cardId, boardId };
  const newLabelSwatches = LABEL_PALETTE.map((c, i) => `<button class="swatch ${i === 0 ? 'selected' : ''}" data-color="${c}" style="background:${c}" onclick="selectNewLabelColor(this)"></button>`).join('');
  const html = `<div class="label-popover" id="floating-label-popover">
    <div class="popover-header"><span>Etiquetas</span><button class="popover-close-btn" onclick="closeLabelPopover()">×</button></div>
    <input type="text" class="popover-search" id="label-popover-search" placeholder="Buscar etiquetas..." oninput="onLabelPopoverSearch(this.value)">
    <div class="label-list" id="label-popover-list">${renderLabelPopoverList(cardId, boardId)}</div>
    <div class="new-label-block">
      <input type="text" id="new-label-name" placeholder="Nome da nova etiqueta...">
      <div class="swatch-row" id="new-label-swatches">${newLabelSwatches}</div>
      <button class="modal-primary-btn" onclick="addLabel('${boardId}','${cardId}')">Criar etiqueta</button>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', html);
  const popover = document.getElementById('floating-label-popover');
  const w = popover.offsetWidth, h = popover.offsetHeight;
  let left = x, top = y;
  if (left + w > window.innerWidth - 8) left = window.innerWidth - w - 8;
  if (left < 8) left = 8;
  if (top + h > window.innerHeight - 8) top = Math.max(8, y - h - 6);
  popover.style.left = left + 'px';
  popover.style.top = top + 'px';
  const searchInput = document.getElementById('label-popover-search');
  if (searchInput) searchInput.focus();
}

function closeLabelPopover() {
  const el = document.getElementById('floating-label-popover');
  if (el) el.remove();
  state.labelPopoverCtx = null;
}

function onLabelPopoverSearch(value) {
  state.labelPopoverSearch = value;
  if (!state.labelPopoverCtx) return;
  const { cardId, boardId } = state.labelPopoverCtx;
  const listEl = document.getElementById('label-popover-list');
  if (listEl) listEl.innerHTML = renderLabelPopoverList(cardId, boardId);
}

async function toggleLabel(cardId, labelId, boardId) {
  const found = findCard(cardId);
  const card = found.card;
  const has = (card.card_labels || []).some(cl => cl.label_id === labelId);
  setSync('saving');
  if (has) {
    await sb.from('card_labels').delete().eq('card_id', cardId).eq('label_id', labelId);
    card.card_labels = card.card_labels.filter(cl => cl.label_id !== labelId);
  } else {
    await sb.from('card_labels').insert({ card_id: cardId, label_id: labelId });
    card.card_labels = [...(card.card_labels || []), { label_id: labelId }];
  }
  setSync('ok');
  refreshLabelUI(cardId, boardId);
}

async function addLabel(boardId, cardId) {
  const input = document.getElementById('new-label-name');
  const name = input.value.trim();
  if (!name) return;
  const selectedSwatch = document.querySelector('#new-label-swatches .swatch.selected');
  const color = selectedSwatch ? selectedSwatch.dataset.color : LABEL_PALETTE[0];
  setSync('saving');
  const { data, error } = await sb.from('labels').insert({ board_id: boardId, name, color }).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  state.labels[boardId].push(data);
  setSync('ok');
  input.value = '';
  await toggleLabel(cardId, data.id, boardId);
}

function selectNewLabelColor(el) {
  document.querySelectorAll('#new-label-swatches .swatch').forEach(s => s.classList.remove('selected'));
  el.classList.add('selected');
}

function startEditLabel(labelId, boardId, cardId) {
  const label = state.labels[boardId].find(l => l.id === labelId);
  if (!label) return;
  state.editingLabelId = labelId;
  state.editLabelDraft = { name: label.name, color: label.color };
  refreshLabelUI(cardId, boardId);
}

function setEditLabelColor(color) {
  state.editLabelDraft.color = color;
  if (!state.labelPopoverCtx) return;
  refreshLabelUI(state.labelPopoverCtx.cardId, state.labelPopoverCtx.boardId);
}

async function saveLabelEdit(boardId, labelId) {
  const draft = state.editLabelDraft;
  const name = (draft.name || '').trim();
  if (!name) return;
  setSync('saving');
  const { error } = await sb.from('labels').update({ name, color: draft.color }).eq('id', labelId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  const label = state.labels[boardId].find(l => l.id === labelId);
  label.name = name;
  label.color = draft.color;
  state.editingLabelId = null;
  state.editLabelDraft = null;
  setSync('ok');
  if (state.labelPopoverCtx) refreshLabelUI(state.labelPopoverCtx.cardId, boardId);
}

function cancelLabelEdit(boardId, cardId) {
  state.editingLabelId = null;
  state.editLabelDraft = null;
  refreshLabelUI(cardId, boardId);
}

async function deleteLabel(boardId, labelId, cardId) {
  if (!confirm('Excluir esta etiqueta? Ela será removida de todos os cards que a usam.')) return;
  setSync('saving');
  const { error } = await sb.from('labels').delete().eq('id', labelId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  state.labels[boardId] = state.labels[boardId].filter(l => l.id !== labelId);
  state.cards[boardId].forEach(c => {
    if (c.card_labels) c.card_labels = c.card_labels.filter(cl => cl.label_id !== labelId);
  });
  state.editingLabelId = null;
  state.editLabelDraft = null;
  setSync('ok');
  refreshLabelUI(cardId, boardId);
}

async function addChecklistItem(cardId) {
  const input = document.getElementById('new-checklist-item');
  const text = input.value.trim();
  if (!text) return;
  const found = findCard(cardId);
  const position = (found.card.checklist_items || []).length;
  setSync('saving');
  const { data, error } = await sb.from('checklist_items').insert({ card_id: cardId, text, position }).select().single();
  if (error) { setSync('error'); return; }
  found.card.checklist_items = [...(found.card.checklist_items || []), data];
  setSync('ok');
  renderModal(found.boardId, found.card);
}

async function toggleChecklistItem(itemId, cardId, done) {
  const found = findCard(cardId);
  const item = found.card.checklist_items.find(i => i.id === itemId);
  if (item) item.done = done;
  setSync('saving');
  const { error } = await sb.from('checklist_items').update({ done }).eq('id', itemId);
  if (error) { setSync('error'); return; }
  setSync('ok');
  renderModal(found.boardId, found.card);
}

async function deleteChecklistItem(itemId, cardId) {
  const found = findCard(cardId);
  setSync('saving');
  const { error } = await sb.from('checklist_items').delete().eq('id', itemId);
  if (error) { setSync('error'); return; }
  found.card.checklist_items = found.card.checklist_items.filter(i => i.id !== itemId);
  setSync('ok');
  renderModal(found.boardId, found.card);
}

async function uploadAttachment(event, cardId) {
  const file = event.target.files[0];
  if (!file) return;
  const found = findCard(cardId);
  setSync('saving');
  const filePath = `${cardId}/${Date.now()}-${file.name}`;
  const { error: uploadErr } = await sb.storage.from('attachments').upload(filePath, file);
  if (uploadErr) { setSync('error'); alert('Erro ao enviar arquivo: ' + uploadErr.message); return; }
  const { data: pub } = sb.storage.from('attachments').getPublicUrl(filePath);
  const { data, error } = await sb.from('attachments').insert({ card_id: cardId, file_name: file.name, file_url: pub.publicUrl }).select().single();
  if (error) { setSync('error'); return; }
  found.card.attachments = [...(found.card.attachments || []), data];
  setSync('ok');
  renderModal(found.boardId, found.card);
}

async function deleteAttachment(attachmentId, cardId) {
  const found = findCard(cardId);
  setSync('saving');
  const { error } = await sb.from('attachments').delete().eq('id', attachmentId);
  if (error) { setSync('error'); return; }
  found.card.attachments = found.card.attachments.filter(a => a.id !== attachmentId);
  setSync('ok');
  renderModal(found.boardId, found.card);
}

async function addAssignee(cardId, boardId) {
  const input = document.getElementById('new-assignee-name');
  const name = input.value.trim();
  if (!name) return;
  const found = findCard(cardId);
  const current = found.card.assignees || [];
  if (current.includes(name)) { input.value = ''; return; }
  const updated = [...current, name];
  setSync('saving');
  const { error } = await sb.from('cards').update({ assignees: updated }).eq('id', cardId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  found.card.assignees = updated;
  setSync('ok');
  renderModal(boardId, found.card);
}

async function removeAssignee(cardId, boardId, index) {
  const found = findCard(cardId);
  const current = found.card.assignees || [];
  const updated = current.filter((_, i) => i !== index);
  setSync('saving');
  const { error } = await sb.from('cards').update({ assignees: updated }).eq('id', cardId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  found.card.assignees = updated;
  setSync('ok');
  renderModal(boardId, found.card);
}

function formatCommentTime(iso) {
  const d = new Date(iso);
  const today = new Date();
  const sameDay = d.toDateString() === today.toDateString();
  const time = d.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
  if (sameDay) return `Hoje às ${time}`;
  return d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' }) + ` às ${time}`;
}

async function addComment(cardId, boardId) {
  const input = document.getElementById('new-comment-text');
  const text = input.value.trim();
  if (!text) return;
  const author = ensureUserName();
  const found = findCard(cardId);
  setSync('saving');
  const { data, error } = await sb.from('card_comments').insert({ card_id: cardId, author, text }).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  found.card.card_comments = [...(found.card.card_comments || []), data];
  setSync('ok');
  renderModal(boardId, found.card);
}

/* ---------- Undo toast ---------- */
let undoTimer = null;
let pendingUndoFn = null;

function showUndoToast(message, undoFn) {
  const existing = document.getElementById('undo-toast');
  if (existing) existing.remove();
  clearTimeout(undoTimer);
  pendingUndoFn = undoFn;
  const html = `<div class="undo-toast" id="undo-toast">
    <span>${escapeHtml(message)}</span>
    <button onclick="runUndo()">Desfazer</button>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', html);
  undoTimer = setTimeout(() => {
    const el = document.getElementById('undo-toast');
    if (el) el.remove();
    pendingUndoFn = null;
  }, 6000);
}

function runUndo() {
  const el = document.getElementById('undo-toast');
  if (el) el.remove();
  clearTimeout(undoTimer);
  if (pendingUndoFn) {
    const fn = pendingUndoFn;
    pendingUndoFn = null;
    fn();
  }
}

async function deleteCard(cardId, boardId) {
  const found = findCard(cardId);
  if (!found) return;
  const card = found.card;
  if (!confirm(`Excluir "${card.title}"? Ela vai para a lixeira por 30 dias — dá pra restaurar depois em Configurações → Lixeira.`)) return;
  const now = new Date().toISOString();
  setSync('saving');
  const { error } = await sb.from('cards').update({ deleted_at: now }).eq('id', cardId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  card.deleted_at = now;
  state.cards[boardId] = state.cards[boardId].filter(c => c.id !== cardId);
  setSync('ok');
  closeModal();
  showUndoToast(`Card "${card.title}" excluído`, async () => {
    setSync('saving');
    const { error: rErr } = await sb.from('cards').update({ deleted_at: null }).eq('id', cardId);
    if (rErr) { setSync('error'); alert('Erro ao desfazer: ' + rErr.message); return; }
    card.deleted_at = null;
    state.cards[boardId].push(card);
    setSync('ok');
    render();
  });
}

let pendingRemoteRefresh = false;
let refreshTimer = null;

function scheduleRefresh() {
  const activeTag = document.activeElement?.tagName;
  const isTyping = activeTag === 'INPUT' || activeTag === 'TEXTAREA';
  const hasOpenPopover = document.getElementById('floating-filter-popover') || document.getElementById('floating-label-popover');
  if (state.openCardId || (isTyping && hasOpenPopover)) {
    pendingRemoteRefresh = true;
    return;
  }
  clearTimeout(refreshTimer);
  refreshTimer = setTimeout(refreshData, 350);
}

function onSearchBlur() {
  if (pendingRemoteRefresh) {
    pendingRemoteRefresh = false;
    refreshData();
  }
}

async function refreshData() {
  await loadAll();
}

function setupRealtime() {
  sb.channel('kanban-family-changes')
    .on('postgres_changes', { event: '*', schema: 'public', table: 'cards' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'columns' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'labels' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'card_labels' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'checklist_items' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'attachments' }, scheduleRefresh)
    .on('postgres_changes', { event: '*', schema: 'public', table: 'boards' }, scheduleRefresh)
    .subscribe();
}

/* ---------- Autenticação ---------- */
let currentAuthEmail = null;

async function sendMagicLink() {
  const emailInput = document.getElementById('auth-email');
  const status = document.getElementById('auth-status');
  const email = emailInput.value.trim();
  if (!email) { status.textContent = 'Digite um e-mail.'; status.className = 'auth-status error'; return; }
  status.textContent = 'Enviando...';
  status.className = 'auth-status';
  const redirectTo = window.location.href.split('#')[0].split('?')[0];
  const { error } = await sb.auth.signInWithOtp({ email, options: { emailRedirectTo: redirectTo } });
  if (error) {
    status.textContent = 'Erro: ' + error.message;
    status.className = 'auth-status error';
    return;
  }
  status.textContent = 'Link enviado! Confira seu e-mail (e a caixa de spam) e clique nele para entrar.';
  status.className = 'auth-status success';
}

async function signOutUser() {
  await sb.auth.signOut();
}

function showAuthGate() {
  document.getElementById('auth-gate').style.display = 'flex';
  document.getElementById('app-shell').style.display = 'none';
}

function showApp() {
  document.getElementById('auth-gate').style.display = 'none';
  document.getElementById('app-shell').style.display = 'flex';
  applyDarkModePreference();
  loadAll();
  setupRealtime();
}

let appStarted = false;
sb.auth.onAuthStateChange((event, session) => {
  if (session && !appStarted) {
    appStarted = true;
    currentAuthEmail = session.user?.email || null;
    showApp();
  } else if (!session) {
    appStarted = false;
    currentAuthEmail = null;
    showAuthGate();
  }
});

(async () => {
  const { data: { session } } = await sb.auth.getSession();
  if (session) {
    appStarted = true;
    currentAuthEmail = session.user?.email || null;
    showApp();
  } else {
    showAuthGate();
  }
})();
</script>
