  </button>`;
  tabs.innerHTML = html;
}

function switchView(view) {
  state.view = view;
  state.filters = { search: '', memberModes: new Set(), dueModes: new Set(), labelIds: new Set() };
  closeFilterPopover();
  renderTabs();
  render();
}

function render() {
  const main = document.getElementById('main');
  if (state.view === 'overview') {
    main.innerHTML = `<div class="overview-wrap">${state.boards.map(renderOverviewBoard).join('')}</div>`;
  } else if (state.view === 'settings') {
    main.innerHTML = renderSettings();
  } else if (state.view === 'trash') {
    main.innerHTML = renderTrashShell();
    loadTrashContent();
  } else {
    const board = state.boards.find(b => b.id === state.view);
    if (!board) return;
    main.innerHTML = renderBoardShell(board);
    renderBoardColumns(board);
  }
}

function filterCards(cards) {
  const { search, memberModes, dueModes, labelIds } = state.filters;
  const userName = getUserName();
  return cards.filter(c => {
    if (search) {
      const q = search.toLowerCase();
      const inTitle = (c.title || '').toLowerCase().includes(q);
      const inDesc = (c.description || '').toLowerCase().includes(q);
      if (!inTitle && !inDesc) return false;
    }
    if (memberModes && memberModes.size) {
      const assignees = c.assignees || [];
      let match = false;
      if (memberModes.has('none') && assignees.length === 0) match = true;
      if (memberModes.has('me') && userName && assignees.includes(userName)) match = true;
      if (!match) return false;
    }
    if (dueModes && dueModes.size) {
      let match = false;
      if (dueModes.has('none') && !c.due_date) match = true;
      if (c.due_date) {
        const due = new Date(c.due_date + 'T00:00:00');
        const today = new Date(); today.setHours(0, 0, 0, 0);
        const diffDays = Math.round((due - today) / 86400000);
        if (dueModes.has('overdue') && diffDays < 0) match = true;
        if (dueModes.has('day') && diffDays >= 0 && diffDays <= 1) match = true;
        if (dueModes.has('week') && diffDays >= 0 && diffDays <= 7) match = true;
        if (dueModes.has('month') && diffDays >= 0 && diffDays <= 31) match = true;
      }
      if (!match) return false;
    }
    if (labelIds && labelIds.size) {
      const cardLabelIds = (c.card_labels || []).map(cl => cl.label_id);
      let match = labelIds.has('none') && cardLabelIds.length === 0;
      if (!match) match = cardLabelIds.some(id => labelIds.has(id));
      if (!match) return false;
    }
    return true;
  });
}

function formatDue(dateStr) {
  if (!dateStr) return null;
  const d = new Date(dateStr + 'T00:00:00');
  const today = new Date(); today.setHours(0,0,0,0);
  const overdue = d < today;
  const label = d.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
  return { label, overdue };
}

function cardLabelBars(card, boardLabels) {
  const labelIds = (card.card_labels || []).map(cl => cl.label_id);
  if (!labelIds.length) return '';
  return labelIds.map(id => {
    const l = boardLabels.find(x => x.id === id);
    if (!l) return '';
    const tooltip = `Cor: ${colorName(l.color)}, título: '${escapeHtml(l.name)}'`;
    return `<div class="card-label-bar" style="background:${l.color}" title="${tooltip}"></div>`;
  }).join('');
}

function initials(name) {
  const parts = (name || '').trim().split(/\s+/).filter(Boolean);
  if (!parts.length) return '?';
  return (parts[0][0] + (parts[1] ? parts[1][0] : '')).toUpperCase();
}

function cardMetaPills(card) {
  const due = formatDue(card.due_date);
  const checklist = card.checklist_items || [];
  const doneCount = checklist.filter(c => c.done).length;
  const assignees = card.assignees || [];
  let pills = '';
  if (due) pills += `<span class="meta-pill due-pill ${due.overdue ? 'overdue' : ''}">🕐 ${due.label}</span>`;
  if (checklist.length) pills += `<span class="meta-pill">☑ ${doneCount}/${checklist.length}</span>`;
  if (card.attachments && card.attachments.length) pills += `<span class="meta-pill">📎 ${card.attachments.length}</span>`;
  if (card.card_comments && card.card_comments.length) pills += `<span class="meta-pill">💬 ${card.card_comments.length}</span>`;
  if (assignees.length) pills += `<span class="meta-pill" title="${escapeHtml(assignees.join(', '))}">👤 ${assignees.map(a => escapeHtml(initials(a))).join(' ')}</span>`;
  return pills ? `<div class="meta-row">${pills}</div>` : '';
}

function renderOverviewBoard(board) {
  const columns = (state.columns[board.id] || []).slice().sort((a,b) => a.position - b.position);
  const cards = state.cards[board.id] || [];
  const labels = state.labels[board.id] || [];
  const cols = columns.map(col => {
    const colCards = cards.filter(c => c.column_id === col.id);
    const cardsHtml = colCards.length
      ? colCards.map(c => `<div class="mini-card" onclick="openCard('${c.id}')">${cardLabelBars(c, labels)}<div class="mini-card-content"><div>${escapeHtml(c.title)}</div>${cardMetaPills(c)}</div></div>`).join('')
      : `<div class="empty-hint">Vazio</div>`;
    return `<div class="mini-column"><div class="name">${escapeHtml(col.name)}</div>${cardsHtml}</div>`;
  }).join('');
  return `<div class="overview-board" style="${accentStyle(board)}">
    <div class="overview-board-header" onclick="switchView('${board.id}')">
      <span class="icon">${boardIcon(board.slug)}</span>
      <h2>${escapeHtml(board.name)}</h2>
      <span class="go">Abrir quadro →</span>
    </div>
    <div class="mini-columns">${cols}</div>
  </div>`;
}

function renderBoardShell(board) {
  const allCards = state.cards[board.id] || [];
  return `<div style="${accentStyle(board)}">
    <div class="board-banner">
      <span class="icon">${boardIcon(board.slug)}</span>
      <div>
        <h1>${escapeHtml(board.name)}</h1>
        <div class="subtitle">${allCards.length} ${allCards.length === 1 ? 'card' : 'cards'} no total</div>
      </div>
    </div>
    <div class="board-inner">
      <div class="filter-bar">
        <button class="filter-trigger-btn" id="filter-trigger-btn" onclick="showFilterPopover(event,'${board.id}')">
          🔎 Filtro <span class="filter-trigger-badge" id="filter-trigger-badge"></span>
        </button>
      </div>
      <div id="board-columns-wrap"></div>
    </div>
  </div>`;
}

function showFilterPopover(event, boardId) {
  closeFilterPopover();
  closeLabelPopover();
  closeCardContextMenu();
  closeColumnMenu();
  const labels = state.labels[boardId] || [];
  const f = state.filters;
  const memberRow = (mode, icon, label) => `<label class="filter-checkbox-row"><input type="checkbox" ${f.memberModes.has(mode) ? 'checked' : ''} onchange="onFilterCheckbox('member','${mode}',this.checked,'${boardId}')"><span class="filter-icon">${icon}</span>${label}</label>`;
  const dueRow = (mode, icon, label) => `<label class="filter-checkbox-row"><input type="checkbox" ${f.dueModes.has(mode) ? 'checked' : ''} onchange="onFilterCheckbox('due','${mode}',this.checked,'${boardId}')"><span class="filter-icon">${icon}</span>${label}</label>`;
  const labelRows = `<label class="filter-checkbox-row"><input type="checkbox" ${f.labelIds.has('none') ? 'checked' : ''} onchange="onFilterCheckbox('label','none',this.checked,'${boardId}')"><span class="filter-icon">🏷</span>Sem etiquetas</label>` +
    labels.map(l => `<label class="filter-checkbox-row"><input type="checkbox" ${f.labelIds.has(l.id) ? 'checked' : ''} onchange="onFilterCheckbox('label','${l.id}',this.checked,'${boardId}')"><span class="filter-label-pill" style="background:${l.color};color:${contrastText(l.color)}">${escapeHtml(l.name)}</span></label>`).join('');

  const html = `<div class="label-popover filter-popover" id="floating-filter-popover">
    <div class="popover-header"><span>Filtro</span><button class="popover-close-btn" onclick="closeFilterPopover()">×</button></div>
    <div class="filter-popover-body">
      <div class="filter-group">
        <div class="filter-group-label">Palavra-chave</div>
        <input type="text" class="popover-search" placeholder="Insira uma palavra-chave..." value="${escapeHtml(f.search)}" oninput="onFilterKeywordInput(this.value,'${boardId}')">
        <div class="filter-hint">Pesquise por título ou descrição.</div>
      </div>
      <div class="filter-group">
        <div class="filter-group-label">Membros</div>
        ${memberRow('none', '👥', 'Sem membros')}
        ${memberRow('me', '🙋', 'Atribuído a mim')}
      </div>
      <div class="filter-group">
        <div class="filter-group-label">Data de entrega</div>
        ${dueRow('none', '📅', 'Sem datas')}
        ${dueRow('overdue', '⚠️', 'Em atraso')}
        ${dueRow('day', '🕐', 'Vence em um dia')}
        ${dueRow('week', '🕐', 'Vence em uma semana')}
        ${dueRow('month', '🕐', 'Vence em um mês')}
      </div>
      <div class="filter-group">
        <div class="filter-group-label">Etiquetas</div>
        ${labelRows}
      </div>
      <button class="modal-primary-btn" style="width:100%;" onclick="clearAllFilters('${boardId}')">Limpar filtros</button>
    </div>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', html);
  const popover = document.getElementById('floating-filter-popover');
  const rect = event.currentTarget.getBoundingClientRect();
  let left = rect.left, top = rect.bottom + 6;
  const w = popover.offsetWidth, h = popover.offsetHeight;
  if (left + w > window.innerWidth - 8) left = window.innerWidth - w - 8;
  if (top + h > window.innerHeight - 8) top = Math.max(8, window.innerHeight - h - 8);
  popover.style.left = left + 'px';
  popover.style.top = top + 'px';
}

function closeFilterPopover() {
  const el = document.getElementById('floating-filter-popover');
  if (el) el.remove();
}

function onFilterKeywordInput(value, boardId) {
  state.filters.search = value;
  renderBoardColumns(state.boards.find(b => b.id === boardId));
  updateFilterBadge();
}

function onFilterCheckbox(type, value, checked, boardId) {
  const set = type === 'member' ? state.filters.memberModes : type === 'due' ? state.filters.dueModes : state.filters.labelIds;
  if (checked) set.add(value); else set.delete(value);
  renderBoardColumns(state.boards.find(b => b.id === boardId));
  updateFilterBadge();
}

function clearAllFilters(boardId) {
  state.filters = { search: '', memberModes: new Set(), dueModes: new Set(), labelIds: new Set() };
  const popover = document.getElementById('floating-filter-popover');
  if (popover) {
    popover.querySelectorAll('input[type=checkbox]').forEach(cb => { cb.checked = false; });
    const kw = popover.querySelector('.popover-search');
    if (kw) kw.value = '';
  }
  renderBoardColumns(state.boards.find(b => b.id === boardId));
  updateFilterBadge();
}

function updateFilterBadge() {
  const f = state.filters;
  const count = f.memberModes.size + f.dueModes.size + f.labelIds.size + (f.search.trim() ? 1 : 0);
  const badge = document.getElementById('filter-trigger-badge');
  if (badge) badge.textContent = count > 0 ? count : '';
  const btn = document.getElementById('filter-trigger-btn');
  if (btn) btn.classList.toggle('active', count > 0);
}

function renderBoardColumns(board) {
  const columns = (state.columns[board.id] || []).slice().sort((a, b) => a.position - b.position);
  const allCards = state.cards[board.id] || [];
  const cards = filterCards(allCards);
  const labels = state.labels[board.id] || [];
  const cols = columns.map((col, idx) => {
    const colCards = cards.filter(c => c.column_id === col.id).sort((a, b) => a.position - b.position);
    const cardsHtml = colCards.length
      ? colCards.map(c => `
      <div class="card" data-card-id="${c.id}">
        ${cardLabelBars(c, labels)}
        <button class="card-menu-btn" onpointerdown="event.stopPropagation()" onclick="event.stopPropagation();const r=this.getBoundingClientRect();showCardContextMenu(r.right,r.bottom+4,'${c.id}','${board.id}')">⋯</button>
        <div class="card-content">
          <div class="title">${escapeHtml(c.title)}</div>
          ${cardMetaPills(c)}
        </div>
      </div>`).join('')
      : `<div class="empty-hint">${allCards.some(c => c.column_id === col.id) ? 'Nenhum card corresponde ao filtro' : 'Arraste um card aqui'}</div>`;
    const columnStyle = col.color ? `background:${col.color}22;` : '';
    const headerStyle = col.color ? `border-bottom-color:${col.color};` : '';
    const nameStyle = col.color ? `color:${col.color};` : '';
    const countStyle = col.color ? `background:${col.color};color:${contrastText(col.color)};` : '';
    const menuBtnStyle = col.color ? `color:${col.color};` : '';
    return `<div class="column" data-column-id="${col.id}" style="${columnStyle}">
      <div class="column-header" style="${headerStyle}">
        <span class="name" style="${nameStyle}">${escapeHtml(col.name)}</span>
        <div class="column-header-right">
          <span class="count" style="${countStyle}">${colCards.length}</span>
          <button class="col-menu-btn" style="${menuBtnStyle}" onclick="showColumnMenu(event,'${board.id}','${col.id}')">⋯</button>
        </div>
      </div>
      <div class="card-list" data-column-id="${col.id}">${cardsHtml}</div>
      <button class="add-card-btn" onclick="promptAddCard('${board.id}','${col.id}')">+ Adicionar card</button>
    </div>`;
  }).join('');
  const wrap = document.getElementById('board-columns-wrap');
  if (!wrap) return;
  wrap.innerHTML = `<div class="board-columns">
    ${cols}
    <button class="add-column-btn" onclick="promptAddColumn('${board.id}')">+ Adicionar coluna</button>
  </div>`;
  attachDnD(board.id);
}

function showColumnMenu(event, boardId, columnId) {
  event.stopPropagation();
  closeColumnMenu();
  const col = state.columns[boardId].find(c => c.id === columnId);
  if (!col) return;
  const colorSwatches = `<button class="swatch swatch-none ${!col.color ? 'selected' : ''}" data-color="" title="Cor padrão do quadro" onclick="setColumnColor('${boardId}','${columnId}',null)"></button>` +
    LABEL_PALETTE.map(c => `<button class="swatch ${col.color === c ? 'selected' : ''}" data-color="${c}" style="background:${c}" onclick="setColumnColor('${boardId}','${columnId}','${c}')"></button>`).join('');
  const menuHtml = `<div class="column-menu" id="floating-column-menu">
    <button onclick="moveColumn('${boardId}','${columnId}',-1);closeColumnMenu();">‹ Mover para esquerda</button>
    <button onclick="moveColumn('${boardId}','${columnId}',1);closeColumnMenu();">Mover para direita ›</button>
    <button onclick="renameColumn('${boardId}','${columnId}');closeColumnMenu();">✎ Renomear coluna</button>
    <div class="column-menu-divider"></div>
    <div class="column-menu-label">Cor da coluna</div>
    <div class="column-menu-swatches">${colorSwatches}</div>
    <div class="column-menu-divider"></div>
    <button class="danger" onclick="deleteColumnPrompt('${boardId}','${columnId}');closeColumnMenu();">🗑 Excluir coluna</button>
  </div>`;
  document.body.insertAdjacentHTML('beforeend', menuHtml);
  const menu = document.getElementById('floating-column-menu');
  const btnRect = event.currentTarget.getBoundingClientRect();
  const menuWidth = menu.offsetWidth;
  const menuHeight = menu.offsetHeight;
  let left = btnRect.right - menuWidth;
  let top = btnRect.bottom + 6;
  if (left < 8) left = 8;
  if (left + menuWidth > window.innerWidth - 8) left = window.innerWidth - menuWidth - 8;
  if (top + menuHeight > window.innerHeight - 8) top = btnRect.top - menuHeight - 6;
  menu.style.position = 'fixed';
  menu.style.left = left + 'px';
  menu.style.top = top + 'px';
}

function closeColumnMenu() {
  const el = document.getElementById('floating-column-menu');
  if (el) el.remove();
}

function refreshColumnMenuSwatches(boardId, columnId) {
  const menu = document.getElementById('floating-column-menu');
  if (!menu) return;
  const col = state.columns[boardId].find(c => c.id === columnId);
  menu.querySelectorAll('.column-menu-swatches .swatch').forEach(el => {
    const val = el.dataset.color || null;
    el.classList.toggle('selected', val === (col.color || null));
  });
}

document.addEventListener('click', e => {
  if (!e.target.closest('#floating-column-menu') && !e.target.closest('.col-menu-btn')) {
    closeColumnMenu();
  }
  if (!e.target.closest('#floating-label-popover') && !e.target.closest('.add-label-btn')) {
    closeLabelPopover();
  }
  if (!e.target.closest('#floating-card-menu') && !e.target.closest('.card-menu-btn')) {
    closeCardContextMenu();
  }
  if (!e.target.closest('#floating-filter-popover') && !e.target.closest('#filter-trigger-btn')) {
    closeFilterPopover();
  }
});

async function renameColumn(boardId, columnId) {
  const col = state.columns[boardId].find(c => c.id === columnId);
  if (!col) return;
  const name = prompt('Novo nome da coluna:', col.name);
  if (!name || !name.trim()) return;
  setSync('saving');
  const { error } = await sb.from('columns').update({ name: name.trim() }).eq('id', columnId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  col.name = name.trim();
  setSync('ok');
  renderBoardColumns(state.boards.find(b => b.id === boardId));
}

async function deleteColumnPrompt(boardId, columnId) {
  const col = state.columns[boardId].find(c => c.id === columnId);
  if (!col) return;
  const cardsInCol = (state.cards[boardId] || []).filter(c => c.column_id === columnId);
  const msg = cardsInCol.length > 0
    ? `Excluir a coluna "${col.name}"? Os ${cardsInCol.length} card(s) dentro dela também vão para a lixeira. Dá pra desfazer logo em seguida.`
    : `Excluir a coluna "${col.name}"? Dá pra desfazer logo em seguida.`;
  if (!confirm(msg)) return;
  const now = new Date().toISOString();
  setSync('saving');
  const { error } = await sb.from('columns').update({ deleted_at: now }).eq('id', columnId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  const cardUpdates = await Promise.all(cardsInCol.map(c => sb.from('cards').update({ deleted_at: now }).eq('id', c.id)));
  col.deleted_at = now;
  cardsInCol.forEach(c => { c.deleted_at = now; });
  state.columns[boardId] = state.columns[boardId].filter(c => c.id !== columnId);
  state.cards[boardId] = state.cards[boardId].filter(c => c.column_id !== columnId);
  setSync('ok');
  render();
  showUndoToast(`Coluna "${col.name}" excluída`, async () => {
    setSync('saving');
    await sb.from('columns').update({ deleted_at: null }).eq('id', columnId);
    await Promise.all(cardsInCol.map(c => sb.from('cards').update({ deleted_at: null }).eq('id', c.id)));
    col.deleted_at = null;
    cardsInCol.forEach(c => { c.deleted_at = null; });
    state.columns[boardId].push(col);
    state.cards[boardId].push(...cardsInCol);
    setSync('ok');
    render();
  });
}

async function setColumnColor(boardId, columnId, color) {
  const col = state.columns[boardId].find(c => c.id === columnId);
  if (!col) return;
  setSync('saving');
  const { error } = await sb.from('columns').update({ color }).eq('id', columnId);
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  col.color = color;
  setSync('ok');
  renderBoardColumns(state.boards.find(b => b.id === boardId));
  refreshColumnMenuSwatches(boardId, columnId);
}

async function moveColumn(boardId, columnId, direction) {
  const cols = state.columns[boardId].slice().sort((a, b) => a.position - b.position);
  const idx = cols.findIndex(c => c.id === columnId);
  const swapIdx = idx + direction;
  if (swapIdx < 0 || swapIdx >= cols.length) return;
  const a = cols[idx], b = cols[swapIdx];
  const posA = a.position, posB = b.position;
  a.position = posB;
  b.position = posA;
  setSync('saving');
  const results = await Promise.all([
    sb.from('columns').update({ position: a.position }).eq('id', a.id),
    sb.from('columns').update({ position: b.position }).eq('id', b.id),
  ]);
  if (results.some(r => r.error)) { setSync('error'); alert('Erro ao mover coluna'); return; }
  setSync('ok');
  renderBoardColumns(state.boards.find(bd => bd.id === boardId));
}

function escapeHtml(str) {
  const d = document.createElement('div');
  d.textContent = str || '';
  return d.innerHTML;
}

/* ---------- Column / Card creation ---------- */
async function promptAddColumn(boardId) {
  const name = prompt('Nome da coluna:');
  if (!name) return;
  const columns = state.columns[boardId] || [];
  setSync('saving');
  const { data, error } = await sb.from('columns').insert({ board_id: boardId, name, position: columns.length }).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  state.columns[boardId].push(data);
  setSync('ok');
  render();
}

async function promptAddCard(boardId, columnId) {
  const title = prompt('Título do card:');
  if (!title) return;
  const userName = ensureUserName();
  const cards = (state.cards[boardId] || []).filter(c => c.column_id === columnId);
  setSync('saving');
  const { data, error } = await sb.from('cards').insert({ board_id: boardId, column_id: columnId, title, position: cards.length, created_by: userName, updated_by: userName }).select().single();
  if (error) { setSync('error'); alert('Erro: ' + error.message); return; }
  data.card_labels = []; data.checklist_items = []; data.attachments = []; data.assignees = []; data.card_comments = [];
  state.cards[boardId].push(data);
  setSync('ok');
  renderBoardColumns(state.boards.find(b => b.id === boardId));
}

/* ---------- Drag and drop (mouse + touch via Pointer Events) ---------- */
function attachDnD(boardId) {
  document.querySelectorAll('.card[data-card-id]').forEach(el => {
    el.addEventListener('pointerdown', e => startCardDrag(e, el, boardId));
    el.addEventListener('contextmenu', e => {
      e.preventDefault();
      showCardContextMenu(e.clientX, e.clientY, el.dataset.cardId, boardId);
    });
  });
}

function startCardDrag(e, el, boardId) {
  if (e.button !== undefined && e.button !== 0 && e.pointerType === 'mouse') return;
  const startX = e.clientX, startY = e.clientY;
  const cardId = el.dataset.cardId;
  const origRect = el.getBoundingClientRect();
  let dragging = false;
  let ghost = null;

  function onMove(ev) {
    const dx = ev.clientX - startX, dy = ev.clientY - startY;
    if (!dragging && Math.hypot(dx, dy) > 8) {
      dragging = true;
      el.classList.add('dragging');
      ghost = el.cloneNode(true);
      ghost.classList.add('card-ghost');
      ghost.style.width = origRect.width + 'px';
      ghost.style.left = origRect.left + 'px';
      ghost.style.top = origRect.top + 'px';
      document.body.appendChild(ghost);
    }
    if (dragging) {
      ghost.style.left = (origRect.left + dx) + 'px';
      ghost.style.top = (origRect.top + dy) + 'px';
      document.querySelectorAll('.column.drag-over').forEach(c => c.classList.remove('drag-over'));
      const col = document.elementFromPoint(ev.clientX, ev.clientY)?.closest('.column');
      if (col) col.classList.add('drag-over');
    }
  }

  async function onUp(ev) {
    document.removeEventListener('pointermove', onMove);
    document.removeEventListener('pointerup', onUp);
    document.removeEventListener('pointercancel', onUp);
    if (dragging) {
      el.classList.remove('dragging');
      if (ghost) ghost.remove();
      document.querySelectorAll('.column.drag-over').forEach(c => c.classList.remove('drag-over'));
      const dropCol = document.elementFromPoint(ev.clientX, ev.clientY)?.closest('.column');
      if (dropCol) {
        const list = dropCol.querySelector('.card-list');
        const dropIndex = computeDropIndex(list, ev.clientY);
        await moveCard(boardId, cardId, dropCol.dataset.columnId, dropIndex);
      }
    } else {
      openCard(cardId);
    }
  }

  document.addEventListener('pointermove', onMove);
  document.addEventListener('pointerup', onUp);
  document.addEventListener('pointercancel', onUp);
}

function computeDropIndex(listEl, clientY) {
  const cardEls = [...listEl.querySelectorAll('.card')];
  for (let i = 0; i < cardEls.length; i++) {
    const rect = cardEls[i].getBoundingClientRect();
    if (clientY < rect.top + rect.height / 2) return i;
  }
  return cardEls.length;
}

async function moveCard(boardId, cardId, newColumnId, dropIndex) {
  const cards = state.cards[boardId];
  const card = cards.find(c => c.id === cardId);
  if (!card) return;
  const oldColumnId = card.column_id;
  card.column_id = newColumnId;
  card.updated_by = ensureUserName();

  let targetCards = cards.filter(c => c.column_id === newColumnId && c.id !== cardId).sort((a, b) => a.position - b.position);
  const insertAt = Math.max(0, Math.min(dropIndex, targetCards.length));
  targetCards.splice(insertAt, 0, card);
  targetCards.forEach((c, i) => { c.position = i; });

  const updates = targetCards.map(c => {
    const payload = { column_id: c.column_id, position: c.position };
    if (c.id === cardId) payload.updated_by = card.updated_by;
    return sb.from('cards').update(payload).eq('id', c.id);
  });

  if (oldColumnId !== newColumnId) {
    const oldCards = cards.filter(c => c.column_id === oldColumnId).sort((a, b) => a.position - b.position);
    oldCards.forEach((c, i) => { c.position = i; });
    updates.push(...oldCards.map(c => sb.from('cards').update({ position: c.position }).eq('id', c.id)));
  }

  setSync('saving');
  const results = await Promise.all(updates);
  const failed = results.find(r => r.error);
  if (failed) { setSync('error'); alert('Erro ao mover: ' + failed.error.message); return; }
  setSync('ok');
  renderBoardColumns(state.boards.find(b => b.id === boardId));
}

async function moveCardToColumn(boardId, cardId, newColumnId) {
  const targetCount = state.cards[boardId].filter(c => c.column_id === newColumnId).length;
  await moveCard(boardId, cardId, newColumnId, targetCount);
}

