.comment-composer button{ align-self:flex-end; }

.del-btn{ all: unset; cursor: pointer; opacity:.55; transition:var(--transition); padding: 3px 7px; border-radius: 6px; }
.del-btn:hover{ opacity:1; color:var(--danger); }

button:hover{ transition:var(--transition); }
input{ transition:var(--transition); }
textarea{ transition:var(--transition); }
select{ transition:var(--transition); }

.overview-board-header, .column, .filter-bar input{ backdrop-filter:blur(12px); }

::selection{ background:#5B7CFA; color:white; }

button:focus-visible{ outline:none; box-shadow: 0 0 0 4px rgba(91,124,250,.18); }
input:focus-visible{ outline:none; }
textarea:focus-visible{ outline:none; }

.card, .column, button, input, textarea, select, .modal, .overview-board-header, .mini-card{
    transition: .25s cubic-bezier(.2,.8,.2,1);
}

@keyframes dropdownOpen{ from{ opacity:0; transform: translateY(-8px) scale(.96); } to{ opacity:1; transform: translateY(0) scale(1); } }

